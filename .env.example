# Kopieren nach ".env" und ausfuellen. ".env" NIEMALS committen.

# --- WebUntis Zugangsdaten ---
# UNTIS_SERVER: nur der Host, ohne https:// und ohne Pfad.
# Findest du in der Adresszeile, wenn du im Browser bei WebUntis eingeloggt bist,
# z.B. https://nessa.webuntis.com/WebUntis/... -> UNTIS_SERVER=nessa.webuntis.com
UNTIS_SERVER=nessa.webuntis.com

# UNTIS_SCHOOL: der Schulname/-kuerzel, wie er bei der Schulauswahl in WebUntis steht.
UNTIS_SCHOOL=musterschule

# Normaler WebUntis-Login (Schueler-/Eltern-/Lehrer-Konto).
UNTIS_USERNAME=max.mustermann
UNTIS_PASSWORD=hier-echtes-passwort-eintragen

# Frei waehlbar, taucht nur in WebUntis-Logs als Client-Kennung auf.
UNTIS_USERAGENT=Ida-Untis-MCP

# --- Absicherung des MCP-Endpunkts ---
# Langes zufaelliges Geheimnis, das Claude beim Verbinden mitschicken muss.
# Erzeugen z.B. mit: openssl rand -hex 32
MCP_AUTH_TOKEN=hier-langes-zufaelliges-token-eintragen

# Lokaler Port, den docker-compose auf 127.0.0.1 published (siehe docker-compose.yml).
MCP_PORT=8000

# --- Nur fuer docker-compose (Image-Referenz aus GHCR) ---
# Dein GitHub-Benutzername/-Organisation in Kleinbuchstaben.
GITHUB_OWNER=l8tenever
IMAGE_TAG=latest
